        "# ==================\n",
        "# RUN CD\n",
        "# ==================\n",
        "results = {}\n",
        "\n",
        "for expert_name, expert in expert_models.items():\n",
        "    for amateur_name, amateur in amateur_models.items():\n",
        "        #save results to folder\n",
        "        pair_key = f\"expert_{expert_name}_amateur_{amateur_name}\"\n",
        "        results[pair_key] = {}\n",
        "\n",
        "        for domain, (prompts, refs) in datasets.items():\n",
        "\n",
        "            save_path = f\"{base_dir}/{folder_name}/results_{pair_key}_{domain}.json\"\n",
        "\n",
        "            if os.path.exists(save_path):\n",
        "                print(f\"Skipping {pair_key} on {domain} — already complete\")\n",
        "                with open(save_path, \"r\") as f:\n",
        "                    results[pair_key][domain] = json.load(f)\n",
        "                continue\n",
        "\n",
        "            outputs = []\n",
        "            print(f\"\\nRunning {pair_key} on {domain}...\")\n",
        "\n",
        "            for prompt in prompts:\n",
        "                text = contrastive_decode_greedy(\n",
        "                    expert,\n",
        "                    amateur,\n",
        "                    opt_67b_tokenizer,\n",
        "                    prompt,\n",
        "                    max_new_tokens=256\n",
        "                )\n",
        "                outputs.append(text)\n",
        "\n",
        "            div_score = diversity(\" \".join(outputs))\n",
        "            mauve_result = mauve.compute_mauve(p_text=outputs, q_text=refs)\n",
        "            mauve_score = mauve_result.mauve\n",
        "            #coherence = compute_coherence(prompts, outputs)\n",
        "\n",
        "            domain_metrics = {\n",
        "                \"diversity\": div_score,\n",
        "                \"mauve\": mauve_score,\n",
        "                #\"coherence\": coherence,\n",
        "                #\"generations\": outputs\n",
        "            }\n",
        "\n",
        "            results[pair_key][domain] = domain_metrics\n",
        "\n",
        "            with open(save_path, \"w\") as f:\n",
        "                json.dump(domain_metrics, f)\n",
        "\n",
        "            print(\n",
        "                f\"diversity: {div_score:.4f} | \"\n",
        "                f\"mauve: {mauve_score:.4f} | \"\n",
        "                #f\"coherence: {coherence:.4f}\"\n",
        "            )"
