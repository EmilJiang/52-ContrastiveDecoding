    {
      "cell_type": "markdown",
      "source": [
        "# Nucleus\n",
        "\n"
      ],
      "metadata": {
        "id": "RQsdXNJSzSYM"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "@torch.no_grad()\n",
        "def nucleus(model, tokenizer, prompt, max_new_tokens=256, top_p=0.95):\n",
        "    input_ids = tokenizer.encode(prompt, return_tensors=\"pt\").to(model.device)\n",
        "    copy = input_ids.clone()\n",
        "\n",
        "    for _ in range(max_new_tokens):\n",
        "        outputs = model(copy)\n",
        "        token_logits = outputs.logits[:, -1, :]\n",
        "\n",
        "        probs = F.softmax(token_logits, dim=-1)\n",
        "\n",
        "        sorted_probs, sorted_idx = torch.sort(probs, descending=True, dim=-1)\n",
        "        cum_probs = torch.cumsum(sorted_probs, dim=-1)\n",
        "\n",
        "        keep = cum_probs <= top_p\n",
        "        keep[..., 0] = True\n",
        "\n",
        "        filtered_probs = sorted_probs.masked_fill(~keep, 0.0)\n",
        "\n",
        "        filtered_probs = filtered_probs / filtered_probs.sum(dim=-1, keepdim=True)\n",
        "\n",
        "        sampled_pos = torch.multinomial(filtered_probs, num_samples=1)\n",
        "        next_token = sorted_idx.gather(-1, sampled_pos)\n",
        "\n",
        "        copy = torch.cat([copy, next_token], dim=-1)\n",
        "\n",
        "        if next_token.item() == tokenizer.eos_token_id:\n",
        "            break\n",
        "\n",
        "    ret = copy[:, input_ids.shape[1]:]\n",
        "    return tokenizer.decode(ret[0], skip_special_tokens=True)"
      ],
      "metadata": {
        "id": "l8DVUpYszIdW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
