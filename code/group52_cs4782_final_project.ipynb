      "cell_type": "code",
      "source": [
        "\"\"\"\n",
        "Contrastive Decoding alpha sweep — DIV / MAUVE / COH plots\n",
        "Run in Google Colab (or anywhere with matplotlib).\n",
        "Saves three PNGs and also a combined 1x3 figure.\n",
        "\"\"\"\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# data\n",
        "alphas = [0.01, 0.05, 0.1, 0.2]\n",
        "\n",
        "data = {\n",
        "    \"wikinews\": {\n",
        "        \"DIV\":   [0.99, 0.95, 0.90, 0.86],\n",
        "        \"MAUVE\": [0.48, 0.92, 0.95, 0.83],\n",
        "        \"COH\":   [0.48, 0.56, 0.58, 0.59],\n",
        "    },\n",
        "    \"wikitext\": {\n",
        "        \"DIV\":   [0.98, 0.91, 0.82, 0.65],\n",
        "        \"MAUVE\": [0.18, 0.75, 0.85, 0.84],\n",
        "        \"COH\":   [0.56, 0.63, 0.65, 0.65],\n",
        "    },\n",
        "    \"story\": {\n",
        "        \"DIV\":   [0.99, 0.91, 0.75, 0.52],\n",
        "        \"MAUVE\": [0.06, 0.68, 0.35, 0.27],\n",
        "        \"COH\":   [0.39, 0.49, 0.54, 0.55],\n",
        "    },\n",
        "}\n",
        "\n",
        "# Consistent colors per dataset across all plots\n",
        "colors = {\n",
        "    \"wikinews\": \"tab:blue\",\n",
        "    \"wikitext\": \"tab:orange\",\n",
        "    \"story\":    \"tab:green\",\n",
        "}\n",
        "\n",
        "datasets = [\"wikinews\", \"wikitext\", \"story\"]\n",
        "metrics  = [\"DIV\", \"MAUVE\", \"COH\"]\n",
        "\n",
        "# Single plot\n",
        "def plot_and_save(metric, filename):\n",
        "    plt.figure(figsize=(7, 4.5))\n",
        "\n",
        "    for dataset in datasets:\n",
        "        plt.plot(\n",
        "            alphas,\n",
        "            data[dataset][metric],\n",
        "            marker=\"o\",\n",
        "            label=dataset,\n",
        "            color=colors[dataset],\n",
        "        )\n",
        "\n",
        "    # The CD paper's recommended default\n",
        "    plt.axvline(0.1, linestyle=\"--\", color=\"gray\", alpha=0.7,\n",
        "                label=\"α = 0.1 (paper default)\")\n",
        "\n",
        "    plt.title(f\"{metric} vs α  (Contrastive Decoding sweep)\")\n",
        "    plt.xlabel(\"α (plausibility threshold)\")\n",
        "    plt.ylabel(metric)\n",
        "    plt.xticks(alphas, [str(a) for a in alphas])\n",
        "    plt.ylim(0, 1.05)             # all three metrics live in [0, 1]\n",
        "    plt.grid(True, alpha=0.3)\n",
        "    plt.legend()\n",
        "    plt.tight_layout()\n",
        "\n",
        "    plt.savefig(filename, dpi=300, bbox_inches=\"tight\")\n",
        "    plt.show()\n",
        "    plt.close()\n",
        "\n",
        "\n",
        "plot_and_save(\"DIV\",   \"cd_alpha_div.png\")\n",
        "plot_and_save(\"MAUVE\", \"cd_alpha_mauve.png\")\n",
        "plot_and_save(\"COH\",   \"cd_alpha_coh.png\")\n",
        "\n",
        "\n",
        "# Combined 1x3 figure\n",
        "fig, axes = plt.subplots(1, 3, figsize=(16, 4.5), sharex=True)\n",
        "\n",
        "for ax, metric in zip(axes, metrics):\n",
        "    for dataset in datasets:\n",
        "        ax.plot(\n",
        "            alphas,\n",
        "            data[dataset][metric],\n",
        "            marker=\"o\",\n",
        "            label=dataset,\n",
        "            color=colors[dataset],\n",
        "        )\n",
        "    ax.axvline(0.1, linestyle=\"--\", color=\"gray\", alpha=0.7)\n",
        "    ax.set_title(f\"{metric} vs α\")\n",
        "    ax.set_xlabel(\"α\")\n",
        "    ax.set_ylabel(metric)\n",
        "    ax.set_xticks(alphas)\n",
        "    ax.set_xticklabels([str(a) for a in alphas])\n",
        "    ax.set_ylim(0, 1.05)\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "# One legend for the whole figure\n",
        "axes[-1].legend(loc=\"lower right\")\n",
        "fig.suptitle(\"Contrastive Decoding: metric trade-offs across α\", y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"cd_alpha_combined.png\", dpi=300, bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "plt.close()\n",
        "#OPT model diagrams"
