      "source": [
        "## Coherence"
      ],
      "metadata": {
        "id": "NRV8HjpBbSyX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install -q transformers torch\n",
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "from transformers import AutoTokenizer, AutoModel\n",
        "\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "\n",
        "model_name = \"princeton-nlp/sup-simcse-bert-base-uncased\"\n",
        "simcse_tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "simcse_model = AutoModel.from_pretrained(model_name).to(device)\n",
        "\n",
        "def encode(texts):\n",
        "    inputs = simcse_tokenizer(\n",
        "        texts,\n",
        "        padding=True,\n",
        "        truncation=True,\n",
        "        return_tensors=\"pt\"\n",
        "    ).to(device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = simcse_model(**inputs, output_hidden_states=True, return_dict=True)\n",
        "        embeddings = outputs.pooler_output\n",
        "\n",
        "    return embeddings\n",
        "\n",
        "def coherence(prompt, continuation):\n",
        "    embeddings = encode([prompt, continuation])\n",
        "    cos_sim = F.cosine_similarity(embeddings[0:1], embeddings[1:2])\n",
        "    return cos_sim.item()"
      ],
      "metadata": {
        "id": "X0GWldfN8-NV"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Datasets"
      ],
      "metadata": {
        "id": "rM9q_LBEpgYD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install -q datasets\n",
        "\n",
        "from datasets import load_dataset\n",
        "import random\n",
        "\n",
        "print(\"start\")\n",
        "random.seed(42)\n",
        "\n",
        "NUM_PROMPTS = 100\n",
        "PROMPT_WORDS = 32\n",
        "REF_TOKENS = 256\n",
        "\n",
        "def extract_prompts_and_refs_32_words(texts, tokenizer, n=NUM_PROMPTS, prompt_words=PROMPT_WORDS, ref_tokens=REF_TOKENS):\n",
        "    prompts, refs = [], []\n",
        "    candidates = []\n",
        "\n",
        "    for t in texts:\n",
        "        t = t.strip()\n",
        "        if not t:\n",
        "            continue\n",
        "\n",
        "        words = t.split()\n",
        "        if len(words) <= prompt_words:\n",
        "            continue\n",
        "\n",
        "        prompt = \" \".join(words[:prompt_words])\n",
        "        prompt_ids = tokenizer.encode(prompt)\n",
        "        full_ids = tokenizer.encode(t)\n",
        "\n",
        "        # Need enough tokens\n",
        "        if len(full_ids) >= len(prompt_ids) + ref_tokens:\n",
        "            candidates.append((prompt, full_ids, len(prompt_ids)))\n",
        "\n",
        "    if len(candidates) == 0:\n",
        "        print(\"WARNING: no valid candidates found\")\n",
        "        return [], []\n",
        "\n",
        "    sample = random.sample(candidates, min(n, len(candidates)))\n",
        "\n",
        "    for prompt, full_ids, prompt_len in sample:\n",
        "        ref_ids = full_ids[prompt_len:prompt_len + ref_tokens]\n",
        "\n",
        "        prompts.append(prompt)\n",
        "        refs.append(tokenizer.decode(ref_ids, skip_special_tokens=True))\n",
        "\n",
        "    return prompts, refs\n",
        "\n",
        "\n",
        "def inspect_dataset(name, prompts, refs, tokenizer, k=3):\n",
        "    print(\"=\" * 100)\n",
        "    print(name)\n",
        "    print(\"num prompts:\", len(prompts))\n",
        "\n",
        "    if len(prompts) == 0:\n",
        "        return\n",
        "\n",
        "    print(\"avg prompt words:\", sum(len(p.split()) for p in prompts) / len(prompts))\n",
        "    print(\"avg ref tokens:\", sum(len(tokenizer.encode(r)) for r in refs) / len(refs))\n",
        "\n",
        "    for i in random.sample(range(len(prompts)), min(k, len(prompts))):\n",
        "        print(\"-\" * 100)\n",
        "        print(\"PROMPT WORDS:\", len(prompts[i].split()))\n",
        "        print(\"PROMPT:\")\n",
        "        print(prompts[i])\n",
        "        print()\n",
        "        print(\"REF TOKENS:\", len(tokenizer.encode(refs[i])))\n",
        "        print(\"REFERENCE START:\")\n",
        "        print(refs[i][:700])\n",
        "\n",
        "\n",
        "print(\"load\")\n",
        "\n",
        "\n",
        "# WikiText\n",
        "print(\"loading wikitext\")\n",
        "wikitext_raw = load_dataset(\n",
        "    \"wikitext\",\n",
        "    \"wikitext-103-v1\",\n",
        "    split=\"train\",\n",
        "    streaming=True\n",
        ")\n",
        "\n",
        "wiki_texts = []\n",
        "for x in wikitext_raw.take(20000):\n",
        "    text = x[\"text\"].strip()\n",
        "    if text:\n",
        "        wiki_texts.append(text)\n",
        "\n",
        "# wiki_prompts, wiki_refs = extract_prompts_and_refs_32_words(\n",
        "#     wiki_texts,\n",
        "#     gpt2_xl_tokenizer,\n",
        "#     n=NUM_PROMPTS\n",
        "# )\n",
        "\n",
        "wiki_prompts, wiki_refs = extract_prompts_and_refs_32_words(\n",
        "    wiki_texts,\n",
        "    opt_67b_tokenizer,\n",
        "    n=NUM_PROMPTS\n",
        ")\n",
        "\n",
        "\n",
        "# WikiNews approximation using CC-News\n",
        "print(\"loading cc_news\")\n",
        "ccnews_raw = load_dataset(\n",
        "    \"cc_news\",\n",
        "    split=\"train\",\n",
        "    streaming=True\n",
        ")\n",
        "\n",
        "news_texts = []\n",
        "for x in ccnews_raw.take(5000):\n",
        "    text = x[\"text\"].strip()\n",
        "    if text:\n",
        "        news_texts.append(text)\n",
        "\n",
        "# news_prompts, news_refs = extract_prompts_and_refs_32_words(\n",
        "#     news_texts,\n",
        "#     gpt2_xl_tokenizer,\n",
        "#     n=NUM_PROMPTS\n",
        "# )\n",
        "\n",
        "news_prompts, news_refs = extract_prompts_and_refs_32_words(\n",
        "    news_texts,\n",
        "    opt_67b_tokenizer,\n",
        "    n=NUM_PROMPTS\n",
        ")\n",
        "\n",
        "# PG-19 / Story\n",
        "\n",
        "print(\"loading pg19 story data\")\n",
        "\n",
        "stories_raw = load_dataset(\"emozilla/pg19\", split=\"train\", streaming=True)\n",
        "stories_raw = stories_raw.shuffle(buffer_size=1000, seed=42)\n",
        "\n",
        "story_prompts = []\n",
        "story_refs = []\n",
        "\n",
        "random.seed(42)\n",
        "\n",
        "max_books_to_scan = 300\n",
        "chunks_per_book = 3\n",
        "\n",
        "for book_idx, row in enumerate(stories_raw):\n",
        "    if book_idx >= max_books_to_scan:\n",
        "        break\n",
        "\n",
        "    text = row[\"text\"].strip()\n",
        "    if not text:\n",
        "        continue\n",
        "\n",
        "    words = text.split()\n",
        "\n",
        "    if len(words) < 1000:\n",
        "        continue\n",
        "\n",
        "    for _ in range(chunks_per_book):\n",
        "        max_start_word = len(words) - 600\n",
        "        if max_start_word <= 0:\n",
        "            continue\n",
        "\n",
        "        start_word = random.randint(0, max_start_word)\n",
        "\n",
        "        passage_words = words[start_word:start_word + 600]\n",
        "        passage = \" \".join(passage_words)\n",
        "\n",
        "        prompt = \" \".join(passage_words[:PROMPT_WORDS])\n",
        "        # prompt_ids = gpt2_xl_tokenizer.encode(prompt)\n",
        "        # passage_ids = gpt2_xl_tokenizer.encode(passage)\n",
        "        prompt_ids = opt_67b_tokenizer.encode(prompt)\n",
        "        passage_ids = opt_67b_tokenizer.encode(passage)\n",
        "\n",
        "        if len(passage_ids) >= len(prompt_ids) + REF_TOKENS:\n",
        "            ref_ids = passage_ids[len(prompt_ids):len(prompt_ids) + REF_TOKENS]\n",
        "            # ref = gpt2_xl_tokenizer.decode(ref_ids, skip_special_tokens=True)\n",
        "            ref = opt_67b_tokenizer.decode(ref_ids, skip_special_tokens=True)\n",
        "\n",
        "            story_prompts.append(prompt)\n",
        "            story_refs.append(ref)\n",
        "\n",
        "        if len(story_prompts) >= NUM_PROMPTS:\n",
        "            break\n",
        "\n",
        "    if len(story_prompts) >= NUM_PROMPTS:\n",
        "        break\n",
        "\n",
        "\n",
        "print(\"=\" * 100)\n",
        "print(f\"wiki: {len(wiki_prompts)}, news: {len(news_prompts)}, story: {len(story_prompts)}\")\n",
        "\n",
        "# inspect_dataset(\"WIKITEXT\", wiki_prompts, wiki_refs, gpt2_xl_tokenizer)\n",
        "# inspect_dataset(\"CC_NEWS / WIKINEWS APPROX\", news_prompts, news_refs, gpt2_xl_tokenizer)\n",
        "# inspect_dataset(\"PG-19 / STORY\", story_prompts, story_refs, gpt2_xl_tokenizer)"
      ],
      "metadata": {
        "id": "0bW-4Ir8phwk"
      },
      "execution_count": null,
      "outputs": []
