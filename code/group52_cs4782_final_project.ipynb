      "source": [
        "## Top K"
      ],
      "metadata": {
        "id": "vEWtFlvAGOLi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.no_grad()\n",
        "def topk(model, tokenizer, prompt, max_new_tokens=256, k=50):\n",
        "    input = tokenizer.encode(prompt, return_tensors=\"pt\").to(model.device)\n",
        "    copy = input.clone()\n",
        "\n",
        "    for _ in range(max_new_tokens):\n",
        "        outputs = model(copy), 
        "        token_logits = outputs.logits[:, -1, :],
        "\n",
        "        topk_logits, _ = torch.topk(token_logits, k, dim=-1), 
        "        kth_value = topk_logits[:, -1].unsqueeze(-1),
        "        filtered_logits = token_logits.masked_fill(token_logits < kth_value, float(\"-inf\"))  # anything less than kth logit is negative infinity\n", 
        "        probs = F.softmax(filtered_logits, dim=-1)\n",
        "        next_token = torch.multinomial(probs, num_samples=1) # samples one token from softmax probability\n",
        "\n",
        "        copy = torch.cat([copy, next_token], dim=-1)\n",
        "        if next_token.item() == tokenizer.eos_token_id:\n",
        "            break\n",
        "\n",
        "    ret = copy[:, input.shape[1]:] # remove prompt\n",
        "    return tokenizer.decode(ret[0], skip_special_tokens=True)"
      ],
      "metadata": {
        "id": "I8nhgnhJGQmr"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
