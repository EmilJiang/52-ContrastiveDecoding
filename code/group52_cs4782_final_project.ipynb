        "# =========================\n",
        "# EXP2 DATA VISUALIZATION\n",
        "# =========================\n",
        "import json\n",
        "import numpy as np\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "sizes = [\"weak\", \"small\", \"medium\", \"XL\"]\n",
        "domain = \"wiki\"\n",
        "\n",
        "diversity_matrix = np.zeros((4, 4))\n",
        "mauve_matrix = np.zeros((4, 4))\n",
        "\n",
        "for i, expert_name in enumerate(sizes):\n",
        "    for j, amateur_name in enumerate(sizes):\n",
        "        path = f\"{base_dir}/{folder_name}/results_expert_{expert_name}_amateur_{amateur_name}_{domain}.json\"\n",
        "        with open(path, \"r\") as f:\n",
        "            data = json.load(f)\n",
        "        diversity_matrix[i, j] = data[\"diversity\"]\n",
        "        mauve_matrix[i, j] = data[\"mauve\"]\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
        "\n",
        "sns.heatmap(diversity_matrix, annot=True, fmt=\".2f\", ax=axes[0],\n",
        "            xticklabels=sizes, yticklabels=sizes, cmap=\"Greens\")\n",
        "axes[0].set_xlabel(\"amateur\")\n",
        "axes[0].set_ylabel(\"expert\")\n",
        "axes[0].set_title(\"diversity\")\n",
        "\n",
        "sns.heatmap(mauve_matrix, annot=True, fmt=\".2f\", ax=axes[1],\n",
        "            xticklabels=sizes, yticklabels=sizes, cmap=\"Greens\")\n",
        "axes[1].set_xlabel(\"amateur\")\n",
        "axes[1].set_ylabel(\"expert\")\n",
        "axes[1].set_title(\"mauve\")\n",
        "\n",
        "plt.suptitle(\"Contrastive Decoding — OPT on WikiText\")\n",
        "plt.tight_layout()\n",
        "plt.savefig(f\"{base_dir}/{folder_name}/heatmap_wiki.png\", dpi=150)\n",
        "plt.show()"
