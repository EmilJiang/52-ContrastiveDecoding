        "## Greedy"
      ],
      "metadata": {
        "id": "BL-qy1DTF0C2"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.no_grad()\n",
        "def greedy(model, tokenizer, prompt, max_new_tokens=256):\n",
        "    input = tokenizer.encode(prompt, return_tensors=\"pt\").to(model.device)\n",
        "    copy = input.clone()\n",
        "\n",
        "    for _ in range(max_new_tokens):\n",
        "        outputs = model(copy)\n",
        "        token_logits = outputs.logits[:, -1, :]  # scores for next token\n",
        "\n",
        "        next_token = torch.argmax(token_logits, dim=-1, keepdim=True)  # max\n",
        "\n",
        "        copy = torch.cat([copy, next_token], dim=-1)\n",
        "        if next_token.item() == tokenizer.eos_token_id:\n",
        "            break\n",
        "\n",
        "    ret = copy[:, input.shape[1]:]  # remove prompt\n",
        "    return tokenizer.decode(ret[0], skip_special_tokens=True)\n"
      ],
      "metadata": {
        "id": "8nH_8D_GF36O"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.inference_mode()\n",
