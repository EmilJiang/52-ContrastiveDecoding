        "            })\n",
        "        else:\n",
        "            print(f\"  {dataset_name}: FINAL DIV={div}, MAUVE={mv}, COH={coh}\")\n",
        "            final_results.append({\n",
        "                \"Method\": method_name,\n",
        "                \"Dataset\": dataset_name,\n",
        "                \"DIV\": div,\n",
        "                \"MAUVE\": mv,\n",
        "                \"COH\": coh,\n",
        "            })\n",
        "\n",
        "print(\"\\n\" + \"=\" * 80)\n",
        "print(\"FINAL RESULTS\")\n",
        "print(\"=\" * 80)\n",
        "\n",
        "for r in final_results:\n",
        "    print(\n",
        "        f\"{r['Method']} / {r['Dataset']}: \"\n",
        "        f\"DIV={r['DIV']}, MAUVE={r['MAUVE']}, COH={r['COH']}\"\n",
        "    )\n"
