    {
      "cell_type": "code",
      "source": [
        "import json\n",
        "import os\n",
        "import numpy as np\n",
        "import mauve\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "LOG_FILE = \"/content/eval_progress.jsonl\"\n",
        "\n",
        "def save_log(record, log_file=LOG_FILE):\n",
        "    with open(log_file, \"a\") as f:\n",
        "        f.write(json.dumps(record) + \"\\n\")\n",
        "        f.flush()\n",
        "        os.fsync(f.fileno())\n",
        "\n",
        "\n",
        "def run_evaluation(method_fn, prompts, refs, desc=\"\", print_every=5):\n",
        "    if not prompts:\n",
        "        return None, None, None\n",
        "\n",
        "    generations = []\n",
        "    running_divs = []\n",
        "    running_cohs = []\n",
        "\n",
        "    for i, prompt in enumerate(tqdm(prompts, desc=desc, leave=False), start=1):\n",
        "        generation = method_fn(prompt)\n",
        "        generations.append(generation)\n",
        "\n",
        "        cur_div = diversity(generation)\n",
        "        cur_coh = coherence(prompt, generation)\n",
        "\n",
        "        running_divs.append(cur_div)\n",
        "        running_cohs.append(cur_coh)\n",
        "\n",
        "        # Save every sample immediately\n",
        "        # save_log({\n",
        "        #     \"desc\": desc,\n",
        "        #     \"sample_idx\": i,\n",
        "        #     \"prompt\": prompt,\n",
        "        #     \"reference\": refs[i - 1],\n",
        "        #     \"generation\": generation,\n",
        "        #     \"div\": cur_div,\n",
        "        #     \"coh\": cur_coh,\n",
        "        #     \"div_so_far\": float(np.mean(running_divs)),\n",
        "        #     \"coh_so_far\": float(np.mean(running_cohs)),\n",
        "        #     \"status\": \"sample_done\",\n",
        "        # })\n",
        "\n",
        "        if i % print_every == 0 or i == len(prompts):\n",
        "            msg = (\n",
        "                f\"[{desc}] {i}/{len(prompts)} complete | \"\n",
        "                f\"DIV so far={np.mean(running_divs):.3f} | \"\n",
        "                f\"COH so far={np.mean(running_cohs):.3f}\"\n",
        "            )\n",
        "            print(msg)\n",
        "            print(\"Last generation preview:\")\n",
        "            print(generation[:300].replace(\"\\n\", \" \"))\n",
        "            print(\"-\" * 80)\n",
        "\n",
        "    div = float(np.mean(running_divs))\n",
        "\n",
        "    print(f\"[{desc}] Computing MAUVE...\")\n",
        "    save_log({\n",
        "        \"desc\": desc,\n",
        "        \"status\": \"computing_mauve\",\n",
        "        \"num_generations\": len(generations),\n",
        "        \"div_so_far\": div,\n",
        "        \"coh_so_far\": float(np.mean(running_cohs)),\n",
        "    })\n",
        "\n",
        "    mauve_result = mauve.compute_mauve(\n",
        "        p_text=generations,\n",
        "        q_text=refs,\n",
        "        device_id=0,\n",
        "        max_text_length=256,\n",
        "        verbose=False\n",
        "    )\n",
        "\n",
        "    coh = float(np.mean(running_cohs))\n",
        "\n",
        "    final = {\n",
        "        \"desc\": desc,\n",
        "        \"status\": \"final\",\n",
        "        \"DIV\": round(div, 2),\n",
        "        \"MAUVE\": round(mauve_result.mauve, 2),\n",
        "        \"COH\": round(coh, 2),\n",
        "    }\n",
        "    # save_log(final)\n",
        "\n",
        "    return final[\"DIV\"], final[\"MAUVE\"], final[\"COH\"]"
      ],
      "metadata": {
        "id": "5gD6eTG6pmTe"
      },
      "execution_count": null,
      "outputs": []
    },
    {
