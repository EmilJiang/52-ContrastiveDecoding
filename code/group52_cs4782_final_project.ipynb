    {
      "cell_type": "markdown",
      "source": [
        "## CD BEAM\n"
      ],
      "metadata": {
        "id": "YC9boXm2bm_S"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "NOTE: change tau = 0.5 (GPT), tau = 1 (OPT)"
      ],
      "metadata": {
        "id": "zaJwIbwShhNH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.no_grad()\n",
        "def contrastive_decode_beam(\n",
        "    expert_model,\n",
        "    amateur_model,\n",
        "    tokenizer,\n",
        "    prompt,\n",
        "    max_new_tokens=256,\n",
        "    alpha=0.1,\n",
        "    tau=0.5,\n",
        "    beam_size=5,\n",
        "):\n",
        "    input_ids = tokenizer.encode(prompt, return_tensors=\"pt\").to(expert_model.device)\n",
        "\n",
        "    # Each beam stores:\n",
        "    # expert_ids: full prompt + generated tokens\n",
        "    # amateur_ids: last prompt token + generated tokens\n",
        "    # score: cumulative CD score\n",
        "    beams = [(\n",
        "        input_ids.clone(),\n",
        "        input_ids[:, -1:].clone().to(amateur_model.device),\n",
        "        0.0,\n",
        "        False,\n",
        "    )]\n",
        "\n",
        "    eos_id = tokenizer.eos_token_id\n",
        "\n",
        "    for _ in range(max_new_tokens):\n",
        "        all_candidates = []\n",
        "\n",
        "        for expert_ids, amateur_ids, beam_score, ended in beams:\n",
        "            if ended:\n",
        "                all_candidates.append((expert_ids, amateur_ids, beam_score, True))\n",
        "                continue\n",
        "            expert_logits = expert_model(expert_ids).logits[:, -1, :]\n",
        "            amateur_logits = amateur_model(amateur_ids).logits[:, -1, :]\n",
        "            amateur_logits = amateur_logits.to(expert_logits.device) / tau\n",
        "            expert_logprobs = F.log_softmax(expert_logits, dim=-1)\n",
        "            amateur_logprobs = F.log_softmax(amateur_logits, dim=-1)\n",
        "            expert_probs = expert_logprobs.exp()\n",
        "            plausible = expert_probs >= alpha * expert_probs.max(dim=-1, keepdim=True).values\n",
        "            cd_scores = expert_logprobs - amateur_logprobs\n",
        "            cd_scores = cd_scores.masked_fill(~plausible, float(\"-inf\"))\n",
        "            top_scores, top_tokens = torch.topk(cd_scores, k=beam_size, dim=-1)\n",
        "            for token_score, token_id in zip(top_scores[0], top_tokens[0]):\n",
        "                token_id = token_id.view(1, 1)\n",
        "                new_expert_ids = torch.cat(\n",
        "                    [expert_ids, token_id.to(expert_model.device)],\n",
        "                    dim=-1\n",
        "                )\n",
        "                new_amateur_ids = torch.cat(\n",
        "                    [amateur_ids, token_id.to(amateur_model.device)],\n",
        "                    dim=-1\n",
        "                )\n",
        "                new_score = beam_score + token_score.item()\n",
        "                new_ended = eos_id is not None and token_id.item() == eos_id\n",
        "                all_candidates.append((\n",
        "                    new_expert_ids,\n",
        "                    new_amateur_ids,\n",
        "                    new_score,\n",
        "                    new_ended,\n",
        "                ))\n",
        "        all_candidates.sort(key=lambda x: x[2], reverse=True)\n",
        "        beams = all_candidates[:beam_size]\n",
        "        if all(ended for _, _, _, ended in beams):\n",
        "            break\n",
        "    best_expert_ids, _, best_score, _ = max(beams, key=lambda x: x[2])\n",
        "    generated_ids = best_expert_ids[:, input_ids.shape[1]:]\n",
        "\n",
        "    return tokenizer.decode(generated_ids[0], skip_special_tokens=True)"
      ],
      "metadata": {
        "id": "8g5sb55bbpVf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# CD Greedy"
      ],
      "metadata": {
        "id": "-aBi0k7camjc"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "NOTE: change tau = 0.5 (GPT), tau = 1 (OPT)"
      ],
      "metadata": {
        "id": "xD8_TCuGhUqR"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "@torch.no_grad()\n",
        "def contrastive_decode_greedy(expert_model, amateur_model, tokenizer, prompt,\n",
        "                              max_new_tokens=256, alpha=0.1, tau=1):\n",
        "    input_ids = tokenizer.encode(prompt, return_tensors=\"pt\").to(expert_model.device)\n",
        "    amateur_input = input_ids[:, -1:].to(amateur_model.device)\n",
        "\n",
        "    expert_out = expert_model(input_ids, use_cache=True)\n",
        "    expert_past = expert_out.past_key_values\n",
        "    expert_logits = expert_out.logits[:, -1, :]\n",
        "\n",
        "    amateur_out = amateur_model(amateur_input, use_cache=True)\n",
        "    amateur_past = amateur_out.past_key_values\n",
        "    amateur_logits = amateur_out.logits[:, -1, :]\n",
        "\n",
        "    log_alpha = math.log(alpha)\n",
        "    generated = []\n",
        "\n",
        "    for _ in range(max_new_tokens):\n",
        "        amateur_logprobs = F.log_softmax(amateur_logits.to(expert_logits.device) / tau, dim=-1)\n",
        "        expert_logprobs = F.log_softmax(expert_logits, dim=-1)\n",
        "\n",
        "        # Plausibility in log-space\n",
        "        max_logprob = expert_logprobs.max(dim=-1, keepdim=True).values\n",
        "        plausible = expert_logprobs >= (max_logprob + log_alpha)\n",
        "\n",
        "        cd_scores = expert_logprobs - amateur_logprobs\n",
        "        cd_scores = cd_scores.masked_fill(~plausible, float(\"-inf\"))\n",
        "        next_token = torch.argmax(cd_scores, dim=-1, keepdim=True)\n",
        "\n",
        "        if next_token.item() == tokenizer.eos_token_id:\n",
        "            break\n",
        "        generated.append(next_token.item())\n",
        "\n",
        "        # cache\n",
        "        expert_out = expert_model(next_token, past_key_values=expert_past, use_cache=True)\n",
        "        expert_past = expert_out.past_key_values\n",
        "        expert_logits = expert_out.logits[:, -1, :]\n",
        "\n",
        "        amateur_next = next_token.to(amateur_model.device)\n",
        "        amateur_out = amateur_model(amateur_next, past_key_values=amateur_past, use_cache=True)\n",
        "        amateur_past = amateur_out.past_key_values\n",
        "        amateur_logits = amateur_out.logits[:, -1, :]\n",
        "\n",
        "    return tokenizer.decode(generated, skip_special_tokens=True)"
      ],
      "metadata": {
        "id": "ml2p339_ahe_"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **Metrics**"
      ],
      "metadata": {
        "id": "mU3gvQmea2nP"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Diversity"
      ],
      "metadata": {
        "id": "PL8ZLJNOa8Po"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def diversity(text):\n",
        "    tokens = text.split()\n",
        "    div = 1.0\n",
        "\n",
        "    for n in [2, 3, 4]:\n",
        "        ngrams = list(zip(*[tokens[i:] for i in range(n)]))\n",
        "\n",
        "        if len(ngrams) == 0:\n",
        "            return 0.0\n",
        "\n",
        "        div *= len(set(ngrams)) / len(ngrams)\n",
        "\n",
        "    return div"
      ],
      "metadata": {
        "id": "EY7tlYjtbExg"
